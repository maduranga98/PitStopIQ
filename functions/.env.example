# Dialog eSMS configuration for PitStop IQ
# Copy to functions/.env and fill in real values. functions/.env is gitignored.
#
# The POST API flow (section 3.1 of eSMS API docs):
#   1. POST https://esms.dialog.lk/api/v2/user/login  → Bearer token (12 h)
#   2. POST https://e-sms.dialog.lk/api/v2/sms        → send SMS
#
# Register at https://esms.dialog.lk to obtain credentials.

# eSMS account username (typically your mobile number, e.g. 947XXXXXXXX)
ESMS_USERNAME=

# eSMS account password
ESMS_PASSWORD=

# Default sender mask shown to recipients (max 11 characters).
# Individual service centres can override this via their smsSenderName field.
ESMS_MASK=PitStopIQ
