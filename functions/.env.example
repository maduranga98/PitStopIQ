# Dialog eSMS configuration for PitStop IQ
# Copy to functions/.env and fill in real values. functions/.env is gitignored.

# Send-SMS endpoint. Confirm with the Dialog eSMS docs you have access to —
# the exact path may be /api/v1/sms/send, /api/sms, etc. depending on plan.
ESMS_API_URL=https://esms.dialog.lk/api/v1/sms/send

# URL Message Key (JWT) issued by Dialog. Keep secret.
ESMS_BEARER=

# Default sender mask shown to recipients.
ESMS_MASK=Lumora Tech
