rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSuperAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    function isMember(centerId) {
      return request.auth != null
          && exists(/databases/$(database)/documents/servicecenters/$(centerId)/staff/$(request.auth.uid));
    }

    function memberData(centerId) {
      return get(/databases/$(database)/documents/servicecenters/$(centerId)/staff/$(request.auth.uid)).data;
    }

    function hasRole(centerId, roles) {
      return isMember(centerId) && memberData(centerId).role in roles;
    }

    // ── Super Admins ────────────────────────────────────────────────────────────
    match /superadmins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // managed only via Firebase Console / Admin SDK
    }

    // ── User index ────────────────────────────────────────────────────────────
    // Lightweight mapping uid → { centerId, role } so the client can resolve
    // identity on login.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // ── Service Centers ────────────────────────────────────────────────────────
    match /servicecenters/{centerId} {
      allow read: if true;
      allow create: if (request.auth != null && request.auth.uid == centerId) || isSuperAdmin();
      allow update: if hasRole(centerId, ['Owner', 'Manager']) || isSuperAdmin();
      allow delete: if false;

      // Payments sub-collection — super admin only
      match /payments/{paymentId} {
        allow read: if isSuperAdmin();
        allow create: if isSuperAdmin();
        allow update, delete: if false;
      }

      // Customers sub-collection
      match /customers/{customerId} {
        // Public read so the share link /c/:centerId/:customerId works without
        // login. Listing is restricted to staff via the queries used in-app.
        allow read: if true;
        allow create: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist']);
        allow update: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist']);
        allow delete: if false;
      }

      // Vehicles sub-collection
      match /vehicles/{vehicleId} {
        // Public read so the share link surfaces the customer's vehicles.
        allow read: if true;
        // Technician and Cashier = View only; only Owner/Manager/Receptionist can write
        allow create: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist']);
        allow update: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist']);
        allow delete: if false;
      }

      // Services sub-collection (legacy)
      match /services/{serviceId} {
        allow read: if isMember(centerId);
        allow create: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist', 'Technician']);
        // Cashier = View only on service jobs
        allow update: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist', 'Technician']);
        allow delete: if false;
      }

      // Jobs sub-collection — public read for the share link's service history.
      match /jobs/{jobId} {
        allow read: if true;
        allow create: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist', 'Technician']);
        // Cashier = View only on service jobs
        allow update: if hasRole(centerId, ['Owner', 'Manager', 'Receptionist', 'Technician']);
        allow delete: if false;
      }

      // Service price catalog — staff read/write only.
      match /servicePrices/{itemId} {
        allow read: if isMember(centerId);
        allow write: if hasRole(centerId, ['Owner', 'Manager']);
      }

      // SMS logs sub-collection
      match /smsLogs/{logId} {
        allow read: if isMember(centerId);
        // Cashier = None, Receptionist = None for SMS sending
        allow create: if hasRole(centerId, ['Owner', 'Manager', 'Technician']);
        allow update: if false;
        allow delete: if false;
      }

      // Inventory sub-collection
      match /inventory/{itemId} {
        // Technician = None, Receptionist = None; Cashier = View only
        allow read: if hasRole(centerId, ['Owner', 'Manager', 'Cashier']);
        allow create: if hasRole(centerId, ['Owner', 'Manager']);
        // Cashier = View only, so restrict update to Owner/Manager
        allow update: if hasRole(centerId, ['Owner', 'Manager']);
        allow delete: if hasRole(centerId, ['Owner', 'Manager']);
      }

      // Invoices sub-collection
      match /invoices/{invoiceId} {
        // Public read so the share link can surface invoice totals/status.
        allow read: if true;
        // Technician = None for invoices
        allow create: if hasRole(centerId, ['Owner', 'Manager', 'Cashier']);
        allow update: if hasRole(centerId, ['Owner', 'Manager', 'Cashier']);
        allow delete: if false;
      }

      // Invoice sequence counters
      match /counters/{counterId} {
        allow read: if isMember(centerId);
        // Only roles that can create invoices need counter write access
        allow write: if hasRole(centerId, ['Owner', 'Manager', 'Cashier']);
      }

      // Branches sub-collection
      match /branches/{branchId} {
        allow read: if isMember(centerId);
        allow write: if hasRole(centerId, ['Owner', 'Manager']);
      }

      // Staff sub-collection
      match /staff/{staffId} {
        // A user can always read their own staff doc (needed for bootstrap).
        allow read: if isMember(centerId) || request.auth.uid == staffId;
        allow create: if (request.auth.uid == staffId)
                       || hasRole(centerId, ['Owner', 'Manager']);
        // Owner/Manager can update; staff can update their own non-role fields.
        allow update: if hasRole(centerId, ['Owner', 'Manager'])
            || (request.auth.uid == staffId
                && !('role' in request.resource.data.diff(resource.data).affectedKeys())
                && !('active' in request.resource.data.diff(resource.data).affectedKeys()));
        allow delete: if false;

        // Attendance records nested under each staff member.
        match /attendance/{period} {
          allow read: if isMember(centerId) || request.auth.uid == staffId;
          allow write: if hasRole(centerId, ['Owner', 'Manager'])
                       || request.auth.uid == staffId;
        }
      }
    }

    // ── Upgrade Requests ───────────────────────────────────────────────────────
    match /upgradeRequests/{requestId} {
      // Service center owner can create and read their own requests
      allow read: if isSuperAdmin()
                 || (request.auth != null && resource.data.centerId == request.auth.uid);
      allow create: if request.auth != null
                   && request.resource.data.centerId == request.auth.uid;
      // Only super admin can update (approve/reject)
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ── Pending Invites ────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      // Anyone with the document ID can read (needed for invite acceptance without auth)
      allow read: if true;
      // Only Owner/Manager of the target center can create invites
      allow create: if request.auth != null
          && hasRole(request.resource.data.centerId, ['Owner', 'Manager']);
      // Deletion allowed by the invitee (during acceptance) or Owner/Manager
      allow delete: if true;
      allow update: if false;
    }
  }
}
